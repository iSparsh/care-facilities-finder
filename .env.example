# Set both to gate the app behind HTTP Basic Auth (required in production;
# leave unset for local dev). Share these credentials with your one user
# out-of-band (e.g. a text message), not inside the URL you send them.
APP_USERNAME=
APP_PASSWORD=

# Optional. When set, the HTTP response cache uses Redis instead of local
# SQLite. On Render this is wired automatically from the Key Value instance;
# leave unset for local dev (SQLite under .cache/).
REDIS_URL=
